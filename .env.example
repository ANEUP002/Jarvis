# ── Required ─────────────────────────────────────────────────────────────────
# At least one LLM provider key is required. OpenRouter is the primary.

OPENROUTER_API_KEY="sk-or-v1-..."
# Fallback models (comma-separated OpenRouter model IDs)
OPENROUTER_FALLBACK_MODELS="gpt-4o-mini,gpt-4o,nvidia/nemotron-nano-12b-v2-vl:free"

# ── Optional LLM Providers ───────────────────────────────────────────────────
MINIMAX_API_KEY=""
MINIMAX_BASE_URL=https://api.minimax.io/v1
MODEL_DEFAULT=MiniMax-M2.7

GROQ_API_KEY=""
TOGETHERAI_API_KEY=""
GOOGLE_AI_API_KEY=""
DEEPSEEK_API_KEY=""

# ── Optional: Web Search ─────────────────────────────────────────────────────
# DuckDuckGo (ddgs) works without a key. These are for extended search only.
SERPAPI_API_KEY=""
GOOGLE_SEARCH_ENGINE_ID=""
GOOGLE_SEARCH_KEY=""

# ── Optional: Embeddings ─────────────────────────────────────────────────────
# Needed only if you want cloud-based embeddings (local sentence-transformers works without this)
OPENAI_API_KEY=""

# ── Optional: Email (for email tools) ────────────────────────────────────────
EMAIL_SMTP_SERVER="smtp.gmail.com"
EMAIL_SMTP_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_USERNAME="your@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="your@gmail.com"

# ── Optional: TTS Voice ──────────────────────────────────────────────────────
# JARVIS_PIPER_VOICE=en_US-lessac-medium
# JARVIS_WHISPER_MODEL=tiny.en
# JARVIS_OPENAI_TTS_MODEL=gpt-4o-mini-tts
# JARVIS_OPENAI_TTS_VOICE=coral
